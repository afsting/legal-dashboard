# Infrastructure Environment Variables
# Copy this file to .env.local and fill in with your actual credentials
# This file should NOT be committed to version control

# Google OAuth Credentials from Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Facebook OAuth Credentials from Meta Developers Console
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# Bedrock Agent IDs
# Before supervisor architecture: set BEDROCK_AGENT_ID to the chat agent.
# After supervisor architecture (Step 8): set BEDROCK_AGENT_ID to the supervisor agent.
BEDROCK_AGENT_ID=your_bedrock_agent_id
BEDROCK_AGENT_ALIAS_ID=your_bedrock_agent_alias_id

# Supervisor and sub-agent IDs (set after running create-supervisor-agent.js / create-demand-agent.js)
# These are injected into the Lambda as explicit env vars for observability.
BEDROCK_SUPERVISOR_AGENT_ID=
BEDROCK_SUPERVISOR_AGENT_ALIAS_ID=
BEDROCK_DEMAND_AGENT_ID=
BEDROCK_DEMAND_AGENT_ALIAS_ID=
